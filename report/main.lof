\contentsline {figure}{\numberline {C.1}{\ignorespaces Health check endpoint (\texttt {/health}): JSON response confirming database connectivity, document/chunk counts, S3 reachability, SQS reachability, and LLM backend status.}}{63}{figure.caption.267}%
\contentsline {figure}{\numberline {C.2}{\ignorespaces Drift detection endpoint (\texttt {/drift}): JSON response showing probe query mean similarity, standard deviation, alert status, and Shewhart $3\sigma $ control analysis.}}{64}{figure.caption.268}%
\contentsline {figure}{\numberline {C.3}{\ignorespaces RAG query endpoint (\texttt {POST /ask}): full JSON response showing the generated answer, retrieved source documents with titles, URLs, similarity scores, and retrieval mode metadata.}}{64}{figure.caption.269}%
