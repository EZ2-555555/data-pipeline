# ---------------------------------------------------------------------------
# Copy this to .env.learnerlab and fill in your values.
# Used by: make sync-learnerlab / make sync-all
#
# Get values from: Learner Lab → AWS Details → Credentials
#                  AWS Console → CloudFormation → techpulse-dev → Outputs
#
# NOTE: Learner Lab credentials expire every ~4 hours — update before syncing.
# ---------------------------------------------------------------------------

# AWS credentials (rotate from Learner Lab → AWS Details before each session)
AWS_ACCESS_KEY_ID=ASIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SESSION_TOKEN=FwoGZXIvYXdz...   # required for Learner Lab
AWS_REGION=us-east-1

# S3 — from CloudFormation Output "DataBucketName" (or check S3 console)
S3_BUCKET_NAME=techpulse-dev-data-<your-account-id>

# RDS — from CloudFormation Output "PostgresEndpoint"
REMOTE_DB_HOST=techpulse-dev.xxxxxx.us-east-1.rds.amazonaws.com
REMOTE_DB_PORT=5432
REMOTE_DB_NAME=techpulse
REMOTE_DB_USER=postgres
REMOTE_DB_PASSWORD=your-db-password

# Stage (must match the SAM deploy Stage parameter)
STAGE=dev
