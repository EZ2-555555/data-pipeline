# ---------------------------------------------------------------------------
# Copy this to .env.freetier and fill in your values.
# Used by: make sync-freetier / make sync-all
#
# Get values from: AWS Console → CloudFormation → techpulse-dev → Outputs
# ---------------------------------------------------------------------------

# AWS credentials (permanent IAM user — no session token needed)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# S3 — from CloudFormation Output "DataBucketName" (or check S3 console)
S3_BUCKET_NAME=techpulse-dev-data-<your-account-id>

# RDS — from CloudFormation Output "PostgresEndpoint"
REMOTE_DB_HOST=techpulse-dev.xxxxxx.us-east-1.rds.amazonaws.com
REMOTE_DB_PORT=5432
REMOTE_DB_NAME=techpulse
REMOTE_DB_USER=postgres
REMOTE_DB_PASSWORD=your-db-password

# Stage (must match the SAM deploy Stage parameter)
STAGE=dev
