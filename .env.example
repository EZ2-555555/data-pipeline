# ============================================================
# TechPulse Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Database (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techpulse
DB_USER=postgres
DB_PASSWORD=dev

# AWS (for deployed environment)
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=techpulse-data

# LLM Backend: bedrock | ollama | huggingface
LLM_BACKEND=ollama

# Ollama (local dev)
OLLAMA_BASE_URL=http://localhost:11434

# Bedrock (production)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# HuggingFace (fallback)
HF_API_TOKEN=

# Ingestion
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.IR,cs.SE
ARXIV_MAX_RESULTS=100
HN_FETCH_LIMIT=50

# S3 / SQS / CloudWatch (set true for AWS, false for local dev)
S3_ENABLED=false
SQS_ENABLED=false
SQS_QUEUE_URL=
CLOUDWATCH_ENABLED=false

# LocalStack endpoints (leave blank for real AWS)
S3_ENDPOINT_URL=
SQS_ENDPOINT_URL=
CLOUDWATCH_ENDPOINT_URL=

# Local fallback data lake directory
LOCAL_LAKE_DIR=data_lake

# DEV.to
DEVTO_TAGS=machinelearning,ai,python,programming,devops,mlops,webdev,cloud,javascript,opensource,security,database,docker,kubernetes,react,node,rust,golang,datascience,blockchain,api
DEVTO_PER_PAGE=30

# CORS (comma-separated origins; * for local dev)
ALLOWED_ORIGINS=*

# Retrieval
TOP_K=5
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# Reranking weights (alpha + beta + gamma = 1.0)
RERANK_ALPHA=0.6
RERANK_BETA=0.2
RERANK_GAMMA=0.2
RECENCY_LAMBDA=0.01

# Hallucination threshold (0.0 = disabled, 0.3+ for production)
CITATION_GROUNDING_THRESHOLD=0.0

# Stage (dev | staging | prod)
STAGE=dev

# Ollama
OLLAMA_MODEL=llama3.2:3b
